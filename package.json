{
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@tailwindcss/cli": "^4.3.1",
    "tailwindcss": "^4.3.1"
  },
  "scripts": {
    "watchTailwind": "npx @tailwindcss/cli -i ./src/css/input.css -o ./dist/output.css --watch",
    "watchTs": "tsc src/js/index.ts --watch",
    "start": "concurrently \"npm run watchTailwind\" \"npm run watchTs\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
